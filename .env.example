# .env — for manual/dev runs only (bun run src/index.ts)
# When using Claude Code MCP (.mcp.json), set these in the "env" block there instead.
# Bun auto-loads this file from the working directory; .mcp.json env values take precedence.

WEBHOOK_PORT=9443

# Generate with: openssl rand -hex 32
# Must match the Secret field in your GitHub webhook settings exactly.
GITHUB_WEBHOOK_SECRET=

# Fine-grained PAT: Actions (read) is sufficient.
# Classic PAT: public_repo + read:org for public repos.
GITHUB_TOKEN=
